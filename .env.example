RAG_EMBEDDING_BATCH_SIZE=100
RAG_EMBEDDING_MAX_BATCHES_PER_RUN=1000
RAG_EMBEDDING_REQUEST_DELAY=50ms
RAG_EMBEDDING_MAX_CONSECUTIVE_FAILURES=20
RAG_SEARCH_TOP_K=50
RAG_SEARCH_RETRY_TOP_K=150
RAG_SEARCH_RESULT_SIZE=20
RAG_MINIMUM_SIMILARITY=0.55
RAG_INCLUDE_UNKNOWN_REGION=false
RAG_MYSQL_FALLBACK_ENABLED=true
