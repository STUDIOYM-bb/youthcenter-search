YOUTH_CENTER_PATH=/go/ythip/getPlcy
YOUTH_CENTER_API_KEY=

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SPRING_AI_MODEL_CHAT=none
SPRING_AI_MODEL_EMBEDDING=none
RAG_ENABLED=false

POLICY_COLLECTION_ENABLED=false
POLICY_COLLECTION_CRON=0 0 3 * * *
