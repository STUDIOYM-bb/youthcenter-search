# Docker Compose가 사용하는 로컬 환경변수 예제
#
# Spring Boot를 IntelliJ에서 실행할 때는
# config/application-secret.yml을 사용한다.
#
# Spring Boot는 별도 라이브러리 없이는 이 .env 파일을 자동으로 읽지 않는다.

MYSQL_DATABASE=youthcenter_search
MYSQL_USERNAME=youthcenter
MYSQL_PASSWORD=youthcenter_password
MYSQL_ROOT_PASSWORD=root_password

QDRANT_COLLECTION_NAME=youthcenter_policies
